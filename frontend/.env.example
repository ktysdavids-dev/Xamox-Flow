# URL del backend (API + WebSocket).
# Local: REACT_APP_BACKEND_URL=http://localhost:8000
# Con pareja (WiFi): REACT_APP_BACKEND_URL=http://TU_IP:8000
# Producción / Google Play: REACT_APP_BACKEND_URL=https://api.tudominio.com
REACT_APP_BACKEND_URL=http://localhost:8000

# URL pública de la app (compartir en redes, multijugador). Para Google Play usa tu dominio.
# Si no se define, se usa la URL desde la que se abre la app.
# REACT_APP_PUBLIC_URL=https://tudominio.com

# URL de login con Google. Para Google Play usa tu propio auth (no Emergent).
# Si no se define, se usa la URL por defecto (Emergent).
# REACT_APP_AUTH_LOGIN_URL=https://auth.tudominio.com

# Landing de venta y ficha de app
REACT_APP_MARKETING_URL=https://www.xamoxflow.com
REACT_APP_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.xamoxflow.app
