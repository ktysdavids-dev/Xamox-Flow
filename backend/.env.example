# MongoDB (obligatorio)
MONGO_URL=mongodb+srv://...

# JWT
JWT_SECRET=tu-secreto-jwt

# Google OAuth (para "Iniciar con Google")
# Pega aquí el ID de cliente y el secreto que viste al crear el cliente en Google Cloud.
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# Facebook OAuth (para "Iniciar con Facebook")
FACEBOOK_APP_ID=tu-facebook-app-id
FACEBOOK_APP_SECRET=tu-facebook-app-secret

# URL pública del backend (local o producción)
BACKEND_PUBLIC_URL=http://localhost:8000

# Stripe (pago web en landing)
STRIPE_SECRET_KEY=sk_live_o_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recomendado: Price ID creado en Stripe (evita hardcode de precio)
STRIPE_PRICE_ID=price_xxx
# Fallback si no usas STRIPE_PRICE_ID (2,99 EUR = 299)
STRIPE_PROMO_AMOUNT_EUR_CENTS=299
MARKETING_SITE_URL=https://www.xamoxflow.com
PLAY_SITE_URL=https://play.xamoxflow.com
